{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for every better-writer window. Secondary workspace windows use labels of the form `w-<uuid>` built by `open_new_workspace_window`.",
  "windows": ["main", "w-*"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "store:default",
    "core:window:allow-show",
    "core:window:allow-start-dragging"
  ]
}
